---
import SectionImageGallery from '../components/SectionImageGallery.astro';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>PENSAMIENTO AUTISTA - The Difference</title>
  <style>
    body { background-color: black; color: white; font-family: sans-serif; margin: 0; padding: 0; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; min-height: 100vh; overflow-y: auto; box-sizing: border-box; padding-top: 60px; padding-bottom: 100px; }
    .btn-back-dashboard { border: 4px solid white; padding: 15px 30px; font-size: 20px; font-weight: bold; text-transform: uppercase; cursor: pointer; background: transparent; color: white; transition: 0.3s; text-decoration: none; margin-bottom: 40px; display: inline-block; }
    .btn-back-dashboard:hover { border-color: hotpink; color: hotpink; }
    .environment-content { max-width: 800px; width: 100%; text-align: center; font-family: monospace; padding: 0 20px; box-sizing: border-box; min-height: 120vh; }
  </style>
</head>
<body>
  <a href="/dashboard" class="btn-back-dashboard">← THE DIFFERENCE</a>
  <div class="environment-content">
    <SectionImageGallery section="PENSAMIENTOAUTISTA" coverImage="inicio.png" altPrefix="Pensamiento Autista" />
    <p style="color: #6b7280; font-size: 1.1rem; letter-spacing: 0.05em; margin-bottom: 100px;">[ Espacio inicializado. Entorno listo para el desarrollo de contenido. ]</p>
    <p style="color: #4b5563; font-size: 1rem; letter-spacing: 0.05em;">(Desplazamiento vertical activo - El contenido continuará aquí abajo)</p>
  </div>
</body>
</html>