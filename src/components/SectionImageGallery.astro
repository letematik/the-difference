---
import { existsSync, readdirSync } from 'node:fs';
import { join } from 'node:path';

const { section, coverImage = 'inicio.png', altPrefix = 'Workspace' } = Astro.props;

const folderPath = join(process.cwd(), 'public', section);
let images: string[] = [];
let coverSrc: string | null = null;

if (existsSync(folderPath)) {
  const coverPath = join(folderPath, coverImage);
  coverSrc = existsSync(coverPath) ? `/${section}/${coverImage}` : null;

  images = readdirSync(folderPath)
    .filter((file) => /\.(png|jpe?g|webp|svg)$/i.test(file))
    .filter((file) => file !== coverImage)
    .sort((a, b) => {
      const numA = Number(a.match(/^(\d+)/)?.[1] ?? '999999');
      const numB = Number(b.match(/^(\d+)/)?.[1] ?? '999999');
      return numA - numB || a.localeCompare(b);
    })
    .map((file) => `/${section}/${file}`);
}
---

{coverSrc && <img src={coverSrc} class="env-media" alt={`${altPrefix} portada`} />}

<div class="marquee" aria-label="Galería de imágenes">
  <div class="marquee-track">
    {[...images, ...images].map((src, index) => (
      <img src={src} class="env-media marquee-item" alt={`${altPrefix} ${src.split('/').pop()}`} key={`${src}-${index}`} />
    ))}
  </div>
</div>

<style>
  .marquee {
    width: 100%;
    overflow: hidden;
    position: relative;
    margin: 24px 0 60px;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee 24s linear infinite;
    gap: 20px;
  }

  .marquee-item {
    flex: 0 0 auto;
    width: auto;
    max-width: 320px;
    max-height: 320px;
    height: auto;
    margin: 0;
    object-fit: contain;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
</style>
