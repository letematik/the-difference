              <p class="carousel-label">Dashboard / memoria</p>
              <h3>Un recorrido abierto</h3>
              <p>El carrusel convierte la exploración en una experiencia más fluida y evocadora.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const btnEnter = document.getElementById('btn-enter');
      const btnBack = document.getElementById('btn-back');
      const intro = document.getElementById('intro-screen');
      const dash = document.getElementById('dashboard-screen');
      const toggle = document.getElementById('audio-toggle');
      const track = document.getElementById('audio-track');
      const audio = document.getElementById('audio-element');

      if (!btnEnter || !btnBack || !intro || !dash || !toggle || !track || !(audio instanceof HTMLAudioElement)) {
        return;
      }

      let isPlaying = false;

      toggle.addEventListener('click', () => {
        if (!track.value) {
          return;
        }

        if (isPlaying) {
          audio.pause();
          isPlaying = false;
          toggle.textContent = '♪ ON';
        } else {
          audio.play().catch(() => {});
          isPlaying = true;
          toggle.textContent = '♪ OFF';
        }
      });

      track.addEventListener('change', () => {
        const src = track.value;
        audio.src = src;
        audio.load();

        if (src && isPlaying) {
          audio.play().catch(() => {});
        }
      });

      btnEnter.addEventListener('click', () => {
        intro.style.display = 'none';
        dash.style.display = 'flex';
        window.scrollTo(0, 0);
      });

      btnBack.addEventListener('click', () => {
        dash.style.display = 'none';
        intro.style.display = 'flex';
        window.scrollTo(0, 0);
      });
    });
  </script>
</Layout>